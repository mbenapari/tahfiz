{
  "name": "tahfiz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon -w src/server -x tsx src/server/main.ts",
    "start": "cross-env NODE_ENV=production pm2 start src/server/main.ts --name tahfiz",
    "start:docker": "cross-env NODE_ENV=production tsx src/server/main.ts",
    "build": "vite build",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:seed:all": "sequelize-cli db:seed:all",
    "db:seed:one": "sequelize-cli db:seed",
    "db:seed:undo": "sequelize-cli db:seed:undo",
    "db:seed:undo:all": "sequelize-cli db:seed:undo:all",
    "db:seed:status": "sequelize-cli db:seed:status",
    "db:setup": "npm run db:migrate && npm run db:seed:all",
    "db:reset": "npm run db:migrate:undo:all && npm run db:setup",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^7.0.3",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "lusca": "^1.7.0",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "rate-limit-redis": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.11.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.6.0",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "uuid": "^13.0.0",
    "vite-express": "*",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lusca": "^1.7.5",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "vite": "^6.3.3"
  }
}
